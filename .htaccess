RewriteEngine On

# Rediriger vers index.php si le fichier/dossier n'existe pas
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [L,QSA]

# Proteger les dossiers sensibles de l'acces direct
RewriteRule ^config/ - [F,L]
RewriteRule ^models/ - [F,L]
RewriteRule ^sql/ - [F,L]
RewriteRule ^docker/ - [F,L]
RewriteRule ^\.env - [F,L]
RewriteRule ^\.git - [F,L]

# Proteger les fichiers de documentation et config
<FilesMatch "\.(sql|md|env|yml|yaml|sh|conf|ini)$">
    Require all denied
</FilesMatch>

# Autoriser les fichiers PHP (index.php, actions/)
<FilesMatch "\.php$">
    Require all granted
</FilesMatch>

# Desactiver le listing des repertoires
Options -Indexes

# Charset UTF-8
AddDefaultCharset UTF-8
